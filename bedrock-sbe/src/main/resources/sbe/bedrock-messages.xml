<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.bedrock.mm.sbe"
                   id="1"
                   version="1"
                   semanticVersion="1.0.0"
                   description="Bedrock Market Making Messages"
                   byteOrder="littleEndian">

    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <composite name="groupSizeEncoding" description="Repeating group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>

        <composite name="varAsciiEncoding">
            <type name="length" primitiveType="uint32" maxValue="1073741824"/>
            <type name="varData" primitiveType="uint8" length="0" characterEncoding="US-ASCII"/>
        </composite>

        <enum name="SideEnum" encodingType="uint8">
            <validValue name="BUY">1</validValue>
            <validValue name="SELL">2</validValue>
        </enum>

        <enum name="ActionEnum" encodingType="uint8">
            <validValue name="NEW">1</validValue>
            <validValue name="UPDATE">2</validValue>
            <validValue name="DELETE">3</validValue>
        </enum>

        <enum name="OrderStatusEnum" encodingType="uint8">
            <validValue name="NEW">1</validValue>
            <validValue name="PARTIALLY_FILLED">2</validValue>
            <validValue name="FILLED">3</validValue>
            <validValue name="CANCELLED">4</validValue>
            <validValue name="REJECTED">5</validValue>
        </enum>

        <enum name="TimeInForceEnum" encodingType="uint8">
            <validValue name="DAY">1</validValue>
            <validValue name="IOC">2</validValue>
            <validValue name="FOK">3</validValue>
            <validValue name="GTC">4</validValue>
        </enum>

        <enum name="LiquidityEnum" encodingType="uint8">
            <validValue name="MAKER">1</validValue>
            <validValue name="TAKER">2</validValue>
        </enum>

        <enum name="ExecTypeEnum" encodingType="uint8">
            <validValue name="NEW">1</validValue>
            <validValue name="PARTIAL_FILL">2</validValue>
            <validValue name="FILL">3</validValue>
            <validValue name="CANCEL">4</validValue>
            <validValue name="REJECT">5</validValue>
        </enum>
    </types>

    <!-- Market Data Messages -->
    <sbe:message name="MarketTick" id="1001" description="Market tick data">
        <field name="tsExchNs" id="1" type="uint64" description="Exchange timestamp in nanoseconds"/>
        <field name="tsLocalNs" id="2" type="uint64" description="Local timestamp in nanoseconds"/>
        <field name="symbolId" id="3" type="uint32" description="Symbol identifier"/>
        <field name="bidPrice" id="4" type="uint64" description="Bid price (fixed point 1e-8)"/>
        <field name="askPrice" id="5" type="uint64" description="Ask price (fixed point 1e-8)"/>
        <field name="mid" id="6" type="uint64" description="Mid price (fixed point 1e-8)"/>
        <field name="seq" id="7" type="uint64" description="Sequence number"/>
    </sbe:message>

    <sbe:message name="BookDelta" id="1002" description="Order book delta">
        <field name="symbolId" id="1" type="uint32" description="Symbol identifier"/>
        <field name="side" id="2" type="SideEnum" description="Side of the book"/>
        <field name="price" id="3" type="uint64" description="Price level (fixed point 1e-8)"/>
        <field name="qty" id="4" type="uint64" description="Quantity (fixed point 1e-8)"/>
        <field name="action" id="5" type="ActionEnum" description="Action type"/>
        <field name="level" id="6" type="uint32" description="Price level index"/>
        <field name="seq" id="7" type="uint64" description="Sequence number"/>
    </sbe:message>

    <!-- Strategy Messages -->
    <sbe:message name="RegionPlan" id="2000" description="Strategy region plan">
        <field name="symbolId" id="1" type="uint32" description="Symbol identifier"/>
        <field name="side" id="2" type="SideEnum" description="Side"/>
        <field name="minRatio" id="3" type="int32" description="Minimum ratio in ppm"/>
        <field name="maxRatio" id="4" type="int32" description="Maximum ratio in ppm"/>
        <field name="orderCount" id="5" type="uint32" description="Number of orders"/>
        <field name="perQty" id="6" type="uint64" description="Quantity per order (fixed point 1e-8)"/>
        <field name="planId" id="7" type="uint64" description="Plan identifier"/>
    </sbe:message>

    <sbe:message name="OrderCommand" id="2001" description="Order command">
        <field name="clientOrderId" id="1" type="uint64" description="Client order ID"/>
        <field name="symbolId" id="2" type="uint32" description="Symbol identifier"/>
        <field name="side" id="3" type="SideEnum" description="Order side"/>
        <field name="price" id="4" type="uint64" description="Order price (fixed point 1e-8)"/>
        <field name="qty" id="5" type="uint64" description="Order quantity (fixed point 1e-8)"/>
        <field name="tif" id="6" type="TimeInForceEnum" description="Time in force"/>
        <field name="flags" id="7" type="uint32" description="Order flags"/>
        <field name="strategyId" id="8" type="uint16" description="Strategy ID"/>
        <field name="stepId" id="9" type="uint16" description="Step ID"/>
        <field name="tradeUnitId" id="10" type="uint16" description="Trade unit ID"/>
    </sbe:message>

    <!-- Trading Messages -->
    <sbe:message name="OrderAck" id="3001" description="Order acknowledgment">
        <field name="clientOrderId" id="1" type="uint64" description="Client order ID"/>
        <field name="exchOrderId" id="2" type="uint64" description="Exchange order ID"/>
        <field name="status" id="3" type="OrderStatusEnum" description="Order status"/>
        <field name="tsExchNs" id="4" type="uint64" description="Exchange timestamp in nanoseconds"/>
        <field name="tsLocalNs" id="5" type="uint64" description="Local timestamp in nanoseconds"/>
    </sbe:message>

    <sbe:message name="Fill" id="3002" description="Trade fill">
        <field name="clientOrderId" id="1" type="uint64" description="Client order ID"/>
        <field name="exchOrderId" id="2" type="uint64" description="Exchange order ID"/>
        <field name="fillPrice" id="3" type="uint64" description="Fill price (fixed point 1e-8)"/>
        <field name="fillQty" id="4" type="uint64" description="Fill quantity (fixed point 1e-8)"/>
        <field name="tsExchNs" id="5" type="uint64" description="Exchange timestamp in nanoseconds"/>
        <field name="tsLocalNs" id="6" type="uint64" description="Local timestamp in nanoseconds"/>
        <field name="liquidity" id="7" type="LiquidityEnum" description="Liquidity type"/>
    </sbe:message>

    <!-- Unified Event Payload Messages (DTO-compatible) -->
    <sbe:message name="OrderCommandPayload" id="9101" description="Unified order command payload">
        <field name="priceScaled" id="1" type="int64" description="Price scaled by 1e8"/>
        <field name="quantityScaled" id="2" type="int64" description="Quantity scaled by 1e8"/>
        <data name="symbol" id="11" type="varAsciiEncoding"/>
        <data name="side" id="12" type="varAsciiEncoding"/>
        <data name="orderType" id="13" type="varAsciiEncoding"/>
        <data name="timeInForce" id="14" type="varAsciiEncoding"/>
        <data name="strategyId" id="15" type="varAsciiEncoding"/>
        <data name="clientOrderId" id="16" type="varAsciiEncoding"/>
    </sbe:message>

    <sbe:message name="OrderAckPayloadV1" id="9102" description="Unified order ack payload">
        <field name="eventTimeMs" id="1" type="uint64" description="Event time in milliseconds"/>
        <data name="symbol" id="11" type="varAsciiEncoding"/>
        <data name="orderId" id="12" type="varAsciiEncoding"/>
        <data name="clientOrderId" id="13" type="varAsciiEncoding"/>
        <data name="side" id="14" type="varAsciiEncoding"/>
        <data name="orderType" id="15" type="varAsciiEncoding"/>
        <data name="status" id="16" type="varAsciiEncoding"/>
        <data name="price" id="17" type="varAsciiEncoding"/>
        <data name="quantity" id="18" type="varAsciiEncoding"/>
    </sbe:message>

    <sbe:message name="FillPayloadV1" id="9103" description="Unified fill payload">
        <field name="eventTimeMs" id="1" type="uint64" description="Event time in milliseconds"/>
        <data name="symbol" id="11" type="varAsciiEncoding"/>
        <data name="orderId" id="12" type="varAsciiEncoding"/>
        <data name="clientOrderId" id="13" type="varAsciiEncoding"/>
        <data name="tradeId" id="14" type="varAsciiEncoding"/>
        <data name="side" id="15" type="varAsciiEncoding"/>
        <data name="price" id="16" type="varAsciiEncoding"/>
        <data name="quantity" id="17" type="varAsciiEncoding"/>
        <data name="liquidity" id="18" type="varAsciiEncoding"/>
        <data name="commission" id="19" type="varAsciiEncoding"/>
        <data name="commissionAsset" id="20" type="varAsciiEncoding"/>
    </sbe:message>

    <sbe:message name="MarketTickPayloadV1" id="9104" description="Unified market tick payload">
        <field name="timestamp" id="1" type="uint64" description="Tick event timestamp in milliseconds"/>
        <field name="price" id="2" type="int64" description="Tick price (fixed representation)"/>
        <field name="quantity" id="3" type="int64" description="Tick quantity (fixed representation)"/>
        <field name="buy" id="4" type="uint8" description="1=buy, 0=sell"/>
        <field name="sequenceNumber" id="5" type="uint64" description="Tick sequence number"/>
        <data name="symbol" id="11" type="varAsciiEncoding"/>
    </sbe:message>

    <sbe:message name="BookDeltaPayloadV1" id="9105" description="Unified book delta payload">
        <field name="timestamp" id="1" type="uint64" description="Delta event timestamp in milliseconds"/>
        <field name="price" id="2" type="int64" description="Price level (fixed representation)"/>
        <field name="quantity" id="3" type="int64" description="Quantity at level (fixed representation)"/>
        <field name="sequenceNumber" id="4" type="uint64" description="Delta sequence number"/>
        <data name="symbol" id="11" type="varAsciiEncoding"/>
        <data name="side" id="12" type="varAsciiEncoding"/>
        <data name="action" id="13" type="varAsciiEncoding"/>
    </sbe:message>

    <!-- Unified Event Schema Messages (Task #16) -->
    <sbe:message name="BboEvent" id="1100" description="Best bid/offer snapshot">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="bidPrice" id="2" type="int64" description="Best bid price (fixed point 1e-8)"/>
        <field name="bidSize" id="3" type="int64" description="Best bid size (fixed point 1e-8)"/>
        <field name="askPrice" id="4" type="int64" description="Best ask price (fixed point 1e-8)"/>
        <field name="askSize" id="5" type="int64" description="Best ask size (fixed point 1e-8)"/>
        <field name="seqId" id="6" type="uint64" description="Sequence identifier"/>
        <field name="recvNanos" id="7" type="uint64" description="Receive timestamp in nanoseconds"/>
        <field name="exchNanos" id="8" type="uint64" description="Exchange timestamp in nanoseconds"/>
    </sbe:message>

    <sbe:message name="DepthEvent" id="1101" description="Full order book depth">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="levels" id="2" type="int32" description="Number of price levels"/>
        <field name="seqId" id="3" type="uint64" description="Sequence identifier"/>
        <data name="bidPrices" id="11" type="varAsciiEncoding" description="Bid prices (comma-separated fixed-point longs)"/>
        <data name="bidSizes" id="12" type="varAsciiEncoding" description="Bid sizes (comma-separated fixed-point longs)"/>
        <data name="askPrices" id="13" type="varAsciiEncoding" description="Ask prices (comma-separated fixed-point longs)"/>
        <data name="askSizes" id="14" type="varAsciiEncoding" description="Ask sizes (comma-separated fixed-point longs)"/>
    </sbe:message>

    <sbe:message name="TradeEvent" id="1102" description="Trade tick">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="price" id="2" type="int64" description="Trade price (fixed point 1e-8)"/>
        <field name="size" id="3" type="int64" description="Trade size (fixed point 1e-8)"/>
        <field name="isBuy" id="4" type="uint8" description="1 = aggressor buy, 0 = aggressor sell"/>
        <field name="seqId" id="5" type="uint64" description="Sequence identifier"/>
        <field name="recvNanos" id="6" type="uint64" description="Receive timestamp in nanoseconds"/>
        <field name="exchNanos" id="7" type="uint64" description="Exchange timestamp in nanoseconds"/>
    </sbe:message>

    <sbe:message name="QuoteTarget" id="2100" description="Strategy pricing output">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="regionIndex" id="2" type="int32" description="Region/strategy index"/>
        <field name="bidPrice" id="3" type="int64" description="Target bid price (fixed point 1e-8)"/>
        <field name="askPrice" id="4" type="int64" description="Target ask price (fixed point 1e-8)"/>
        <field name="bidSize" id="5" type="int64" description="Target bid size (fixed point 1e-8)"/>
        <field name="askSize" id="6" type="int64" description="Target ask size (fixed point 1e-8)"/>
        <field name="fairMid" id="7" type="int64" description="Fair mid price (fixed point 1e-8)"/>
        <field name="flags" id="8" type="int32" description="Strategy flags (bitfield)"/>
        <field name="seqId" id="9" type="uint64" description="Sequence identifier"/>
        <field name="publishNanos" id="10" type="uint64" description="Publish timestamp in nanoseconds"/>
    </sbe:message>

    <sbe:message name="ExecEvent" id="3100" description="Order execution update">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="internalOrderId" id="2" type="int64" description="Internal order ID"/>
        <field name="exchOrderId" id="3" type="int64" description="Exchange order ID"/>
        <field name="type" id="4" type="ExecTypeEnum" description="Execution type"/>
        <field name="fillPrice" id="5" type="int64" description="Fill price (fixed point 1e-8)"/>
        <field name="fillSize" id="6" type="int64" description="Fill size (fixed point 1e-8)"/>
        <field name="remainSize" id="7" type="int64" description="Remaining size (fixed point 1e-8)"/>
        <field name="isBid" id="9" type="uint8" description="1 = bid fill (buy), 0 = ask fill (sell)"/>
        <field name="seqId" id="8" type="uint64" description="Sequence identifier"/>
    </sbe:message>

    <sbe:message name="PositionEvent" id="3101" description="Position snapshot">
        <field name="instrumentId" id="1" type="int32" description="Instrument identifier"/>
        <field name="netPosition" id="2" type="int64" description="Net position (fixed point 1e-8)"/>
        <field name="delta" id="3" type="int64" description="Position delta (fixed point 1e-8)"/>
        <field name="unrealizedPnl" id="4" type="int64" description="Unrealized PnL (fixed point 1e-8)"/>
        <field name="seqId" id="5" type="uint64" description="Sequence identifier"/>
    </sbe:message>

</sbe:messageSchema>
